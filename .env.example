# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/pptera"

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_***
CLERK_SECRET_KEY=sk_test_***
CLERK_WEBHOOK_SECRET=whsec_***

# Polar Payment
POLAR_ACCESS_TOKEN=***
POLAR_ENV=sandbox
POLAR_WEBHOOK_SECRET=***

# Polar Product IDs (Monthly Plans)
# Plus: $10/mo, 1,000 credits, 20 cards/prompt
POLAR_PRODUCT_PLUS=***
# Pro: $25/mo, 4,000 credits, 60 cards/prompt (Most Popular)
POLAR_PRODUCT_PRO=***
# Ultra: $100/mo, 20,000 credits, 75 cards/prompt
POLAR_PRODUCT_ULTRA=***

# Polar Product IDs (Yearly Plans - billed annually)
# Plus: $8/mo billed annually
POLAR_PRODUCT_YEARLY_PLUS=***
# Pro: $18/mo billed annually
POLAR_PRODUCT_YEARLY_PRO=***
# Ultra: $90/mo billed annually
POLAR_PRODUCT_YEARLY_ULTRA=***

# Polar Credit Top-up Product IDs (One-time purchases)
# 500 credits: $9.99
POLAR_TOPUP_500=***
# 1000 credits: $17.99
POLAR_TOPUP_1000=***
# 2500 credits: $39.99
POLAR_TOPUP_2500=***

# Cron Job Secret (for monthly credit reset)
CRON_SECRET=***

# OpenAI API
OPENAI_API_KEY=sk-***

# Tiered Gemini models (optional — sensible defaults baked in)
# The outline/visual-strategy step defines the whole deck's quality, so it runs on a
# stronger model; mechanical content expansion runs on a cheaper/faster one.
# Lower GEMINI_OUTLINE_MODEL to gemini-2.5-flash if you want faster/cheaper outlines.
GEMINI_OUTLINE_MODEL=gemini-2.5-pro
GEMINI_CONTENT_MODEL=gemini-2.5-flash-lite

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=https://www.pptmaster.app

# SEO
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_google_verification_code

# Google Analytics
# Get your Measurement ID from Google Analytics: Admin → Data Streams → Web
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# IndexNow (for Bing/ChatGPT instant indexing)
# Generate your own key at https://www.bing.com/indexnow
INDEXNOW_KEY=ee3c5ebf5bcd4e038842d7327ece7c32

# Adobe PDF Services (for pixel-perfect + editable PPTX export)
# Get credentials at https://developer.adobe.com/document-services/apis/pdf-services/
ADOBE_PDF_SERVICES_CLIENT_ID=***
ADOBE_PDF_SERVICES_CLIENT_SECRET=***

# Resend Email Configuration
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_***
# Your verified domain email (e.g., hello@pptmaster.app)
RESEND_FROM_EMAIL=hello@pptmaster.app
# Reply-to email for support inquiries
RESEND_REPLY_TO_EMAIL=support@pptmaster.app
