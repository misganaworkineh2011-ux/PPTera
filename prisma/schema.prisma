generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String          @id @default(cuid())
  clerkId             String          @unique
  name                String
  email               String
  emailVerified       Boolean         @default(false)
  image               String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @default(now()) @updatedAt
  credits             Int             @default(0)
  subscriptionPlan    String?
  subscriptionType    String?
  productId           String?
  nextResetDate       DateTime?
  polarCustomerId     String?
  polarSubscriptionId String?
  presentations       Presentation[]
  images              Image[]
  charts              Chart[]
  templates           Template[]
  themes              Theme[]
  resources           Resource[]
  activities          Activity[]
  collaborations      Collaboration[]
  pinnedProjects      PinnedProject[]
  outlines            Outline[]

  @@map("user")
}

model Presentation {
  id             String          @id @default(cuid())
  title          String
  description    String?
  content        Json
  slides         Json
  thumbnailUrl   String?
  isPinned       Boolean         @default(false)
  userId         String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  images         Image[]
  charts         Chart[]
  collaborations Collaboration[]
  activities     Activity[]
  pinnedBy       PinnedProject[]

  @@map("presentation")
}

model Image {
  id             String        @id @default(cuid())
  url            String
  filename       String
  tags           String[]
  userId         String
  presentationId String?
  createdAt      DateTime      @default(now())
  user           User          @relation(fields: [userId], references: [id])
  presentation   Presentation? @relation(fields: [presentationId], references: [id])
}

model Chart {
  id             String        @id @default(cuid())
  type           String // pie, bar, line, table, etc.
  data           Json
  config         Json
  previewUrl     String?
  userId         String
  presentationId String?
  createdAt      DateTime      @default(now())
  user           User          @relation(fields: [userId], references: [id])
  presentation   Presentation? @relation(fields: [presentationId], references: [id])
}

model Template {
  id         String   @id @default(cuid())
  name       String
  category   String // theme, style, industry
  previewUrl String
  config     Json
  isPublic   Boolean  @default(false)
  userId     String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])
}

model Theme {
  id             String   @id @default(cuid())
  name           String
  colors         Json
  fonts          Json
  designElements Json
  isDefault      Boolean  @default(false)
  userId         String?
  createdAt      DateTime @default(now())
  user           User?    @relation(fields: [userId], references: [id])
}

model Resource {
  id        String   @id @default(cuid())
  type      String // font, icon, logo, illustration, photo, component
  name      String
  url       String
  category  String?
  tags      String[]
  userId    String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model Activity {
  id             String        @id @default(cuid())
  type           String // edit, create, delete, share, etc.
  description    String
  userId         String
  presentationId String?
  metadata       Json?
  createdAt      DateTime      @default(now())
  user           User          @relation(fields: [userId], references: [id])
  presentation   Presentation? @relation(fields: [presentationId], references: [id])
}

model Collaboration {
  id             String       @id @default(cuid())
  presentationId String
  userId         String
  role           String // owner, editor, viewer
  createdAt      DateTime     @default(now())
  presentation   Presentation @relation(fields: [presentationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
}

model PinnedProject {
  id             String       @id @default(cuid())
  userId         String
  presentationId String
  pinnedAt       DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id])
  presentation   Presentation @relation(fields: [presentationId], references: [id])
}

// Landing Page Models
model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  status    String   @default("pending") // pending, replied, closed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contact_submission")
}

model CommunityPost {
  id          String            @id @default(cuid())
  title       String
  content     String
  category    String // show-tell, discussion, tips, feature-request
  authorId    String?
  authorName  String
  authorEmail String?
  likes       Int               @default(0)
  views       Int               @default(0)
  isPinned    Boolean           @default(false)
  isApproved  Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  comments    CommunityComment[]

  @@map("community_post")
}

model CommunityComment {
  id          String        @id @default(cuid())
  postId      String
  content     String
  authorName  String
  authorEmail String?
  likes       Int           @default(0)
  isApproved  Boolean       @default(false)
  createdAt   DateTime      @default(now())
  post        CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("community_comment")
}

model JobPosting {
  id          String   @id @default(cuid())
  title       String
  department  String // Engineering, Design, Marketing, Sales, etc.
  location    String // Remote, San Francisco, etc.
  type        String // Full-time, Part-time, Contract
  description String
  requirements String
  benefits    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  applications JobApplication[]

  @@map("job_posting")
}

model JobApplication {
  id        String     @id @default(cuid())
  jobId     String
  name      String
  email     String
  phone     String?
  resume    String // URL to uploaded resume
  coverLetter String?
  linkedIn  String?
  portfolio String?
  status    String     @default("pending") // pending, reviewing, interview, rejected, accepted
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  job       JobPosting @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("job_application")
}

model InspirationGallery {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String
  category    String // business, education, marketing, design, etc.
  tags        String[]
  likes       Int      @default(0)
  views       Int      @default(0)
  authorId    String?
  authorName  String?
  isPublic    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("inspiration_gallery")
}

model InsightPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String
  coverImage  String
  category    String // ai-technology, design, best-practices
  tags        String[]
  author      String
  authorImage String?
  readTime    Int // in minutes
  views       Int      @default(0)
  likes       Int      @default(0)
  isPublished Boolean  @default(false)
  isFeatured  Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("insight_post")
}

model Newsletter {
  id          String   @id @default(cuid())
  email       String   @unique
  isActive    Boolean  @default(true)
  subscribedAt DateTime @default(now())
  unsubscribedAt DateTime?

  @@map("newsletter")
}

model Outline {
  id          String   @id @default(cuid())
  userId      String
  slides      Json     // Array of slide objects
  metadata    Json     // topic, totalSlides, tone, language
  status      String   @default("generating") // generating, completed, failed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("outline")
}
